# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token

# Chat ID where bot operates (optional — if empty, responds in all chats)
CHAT_ID=

# LLM API (OpenAI-compatible, e.g. DeepSeek)
LLM_API_KEY=your_api_key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Jokes file (path to JSON with jokes array)
JOKES_FILE=./data/jokes.json

# Interval: post a joke every N messages
JOKE_INTERVAL=100

# Probe window: try this many messages after interval
PROBE_WINDOW=10

# Quality threshold (0-10): skip if no joke reaches this
QUALITY_THRESHOLD=7

# Dedup window: skip jokes seen in last N jokes
DEDUP_WINDOW=50
